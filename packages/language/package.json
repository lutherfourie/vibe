{
  "name": "@vibe/language",
  "version": "0.0.0",
  "private": true,
  "description": "Vibe language: parser, AST, evaluator, stdlib, FFI, LLM resolver, init pipeline.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./language-server": {
      "import": "./dist/language-server.js"
    }
  },
  "bin": {
    "vibe-language-server": "./dist/language-server.js"
  },
  "files": [
    "dist",
    "src",
    "syntaxes",
    "language-configuration.json",
    "README.md"
  ],
  "scripts": {
    "langium:generate": "langium generate",
    "build": "pnpm run langium:generate && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist src/generated"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "ai": "^6.0.182",
    "chevrotain": "^11.0.3",
    "execa": "^9.6.1",
    "langium": "^4.2.4",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^2.1.9",
    "langium-cli": "^4.2.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
