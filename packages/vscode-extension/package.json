{
  "name": "vibe-vscode",
  "displayName": "Vibe",
  "description": "Authoring support for Vibe (.vibe) — the unified vibecode language.",
  "version": "0.0.0",
  "publisher": "lutherfourie",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=22"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "vibe",
    "vibecode",
    "agents",
    "llm",
    "spec language"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "vibe",
        "aliases": ["Vibe", "vibelang"],
        "extensions": [".vibe"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vibe",
        "scopeName": "source.vibe",
        "path": "./syntaxes/vibe.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vibe.admin",
        "title": "Vibe: Admin Workspace"
      },
      {
        "command": "vibe.refreshLanes",
        "title": "Vibe: Refresh Lanes"
      },
      {
        "command": "vibe.showCliLanes",
        "title": "Vibe: CLI Lanes"
      },
      {
        "command": "vibe.generateLaneGraph",
        "title": "Vibe: Generate Lane Graph"
      },
      {
        "command": "vibe.serveAdmin",
        "title": "Vibe: Local Admin Host"
      },
      {
        "command": "vibe.parseCurrentFile",
        "title": "Vibe: Parse Current File"
      },
      {
        "command": "vibe.showProjectSummary",
        "title": "Vibe: Show Project Summary"
      },
      {
        "command": "vibe.buildAgentsPreview",
        "title": "Vibe: Build AGENTS Preview"
      },
      {
        "command": "vibe.createGameSpreeContract",
        "title": "Vibe: Create GameSpree/Pawfall Project Contract"
      },
      {
        "command": "vibe.init",
        "title": "Vibe: Init Project"
      },
      {
        "command": "vibe.build",
        "title": "Vibe: Build"
      },
      {
        "command": "vibe.sync",
        "title": "Vibe: Sync"
      },
      {
        "command": "vibe.openVaultInObsidian",
        "title": "Vibe: Open Vault in Obsidian"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "vibe.now",
          "name": "Vibe"
        }
      ]
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @vibe/language build",
    "build": "pnpm run build:deps && tsc -p tsconfig.json",
    "test": "pnpm run build:deps && vitest run",
    "clean": "rimraf dist",
    "vscode:prepublish": "pnpm run build"
  },
  "activationEvents": [
    "onCommand:vibe.admin",
    "onCommand:vibe.refreshLanes",
    "onCommand:vibe.showCliLanes",
    "onCommand:vibe.generateLaneGraph",
    "onCommand:vibe.serveAdmin",
    "onCommand:vibe.parseCurrentFile",
    "onCommand:vibe.showProjectSummary",
    "onCommand:vibe.buildAgentsPreview",
    "onCommand:vibe.createGameSpreeContract",
    "onCommand:vibe.init",
    "onCommand:vibe.build",
    "onCommand:vibe.sync",
    "onCommand:vibe.openVaultInObsidian",
    "onLanguage:vibe",
    "onView:vibe.now",
    "workspaceContains:**/.vibe/**"
  ],
  "dependencies": {
    "@vibe/language": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.9"
  }
}
