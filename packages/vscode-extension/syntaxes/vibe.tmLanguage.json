{
  "name": "vibe",
  "scopeName": "source.vibe",
  "fileTypes": [
    ".vibe"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "name": "keyword.control.vibe",
      "match": "\\b(agent|route)\\b"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "//",
          "beginCaptures": {
            "1": {
              "name": "punctuation.whitespace.comment.leading.vibe"
            }
          },
          "end": "(?=$)",
          "name": "comment.line.vibe"
        },
        {
          "name": "comment.block.vibe",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.vibe"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.vibe"
            }
          }
        }
      ]
    }
  }
}
