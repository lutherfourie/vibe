{
  "$schema": "https://nx.dev/schemas/nx-schema.json",
  "name": "vibe",
  "defaultBase": "main",
  "generators": {
    "@nx/js:lib": {
      "buildable": true
    }
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "self:plan": {
      "cache": true
    },
    "vibe:serve": {
      "cache": false
    }
  }
}