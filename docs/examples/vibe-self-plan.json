        "impl": "./tools/language-lane",
        "owns": "packages/language/**",
        "emits": "parser, dispatcher, resolver, and validation changes"
      }
    },
    {
      "name": "runtime_spike_lane",
      "impl": "./tools/runtime-spike-lane",
      "owns": "go/**",
