{
  "name": "vibe",
  "version": "0.0.0",
  "private": true,
  "description": "Vibecade's Vibe monorepo: language, docs, editor support, and self-describing bootstrap artifacts.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm run self:plan && pnpm run test && pnpm run build",
    "lint": "echo \"no lint configured yet\"",
    "self:plan": "pnpm --filter @vibe/language build && pnpm --filter @vibe/language self:plan --out ../../docs/examples/vibe-self-plan.json",
    "test": "pnpm -r test",
    "langium:generate": "pnpm --filter @vibe/language langium:generate"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.4"
}
