{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecade.dev/schemas/vibe-lane-plan.schema.json",
  "title": "Vibe Lane-Plan",
  "description": "Contract for the lane-plan IR consumed by the Go runtime (internal/lanes) via `vibe handoff --plan` and vibe-coord.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "repo", "lanes"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "minLength": 1 },
    "lanes": { "type": "array", "items": { "$ref": "#/$defs/lane" } }
  },
  "$defs": {
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mode"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["codex.web", "local", "autonomous"] },
        "branch": { "type": "string" },
        "reads": { "type": "array", "items": { "type": "string" } },
        "writes": { "type": "array", "items": { "type": "string" } },
        "prompt": { "type": "string" },
        "requires": { "type": "array", "items": { "type": "string" } },
        "autonomous": { "$ref": "#/$defs/autonomous" }
      }
    },
    "autonomous": {
      "type": "object",
      "additionalProperties": false,
      "description": "Long-horizon config for a mode==\"autonomous\" lane. Ignored by other modes.",
      "properties": {
        "progress": { "type": "string" },
        "horizon": { "type": "string" },
        "checkpointEvery": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "research": { "type": "string" }
      }
    }
  }
}
