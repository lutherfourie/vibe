{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*",
    "pnpm-lock.yaml",
    "go/go.mod",
    "schemas/*.json",
    ".github/workflows/*.yml"
  ],
  "globalEnv": [
    "VIBE_*",
    "SUPABASE_*",
    "VERCEL_*",
    "GROK_API_KEY",
    "CLAUDE_API_KEY",
    "NODE_ENV"
  ],
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "langium:generate", "schema:check"],
      "outputs": [".vibe-out/**", "dist/**", "packages/*/dist/**", "web/.next/**"],
      "cache": true
    },
    "langium:generate": {
      "dependsOn": ["^build"],
      "outputs": ["packages/language/src/generated/**"],
      "cache": true
    },
    "schema:check": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "self:plan": {
      "dependsOn": ["^build", "langium:generate"],
      "outputs": [".vibe-out/**"],
      "cache": true
    },
    "vibe:serve": {
      "cache": false,
      "persistent": true
    },
    "vibe:*": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}