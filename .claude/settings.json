{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "vibecade": {
      "source": {
        "source": "directory",
        "path": "."
      }
    }
  },
  "enabledPlugins": {
    "vibe-workbench@vibecade": true
  },
  "permissions": {
    "allow": [
      "Bash(powershell -ExecutionPolicy Bypass -File *vibe_*.ps1*)",
      "Bash(pnpm test*)",
      "Bash(pnpm run *)",
      "Bash(pnpm --filter * test*)",
      "Bash(pnpm --filter * build*)",
      "Bash(pnpm --filter * check*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)"
    ]
  }
}
