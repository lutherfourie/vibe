{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "vibe": {
      "source": {
        "source": "directory",
        "path": "."
      }
    }
  },
  "enabledPlugins": {
    "vibe-workbench@vibe": true
  },
  "permissions": {
    "allow": [
      "Bash(powershell -ExecutionPolicy Bypass -File *vibe_*.ps1*)",
      "Bash(pnpm test*)",
      "Bash(pnpm run *)",
      "Bash(pnpm --filter * test*)",
      "Bash(pnpm --filter * build*)",
      "Bash(pnpm --filter * check*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}/plugins/vibe-workbench/scripts/vibe_repo_snapshot.ps1\""
          }
        ]
      }
    ]
  }
}
