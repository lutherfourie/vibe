// Pawfall cat asset generation + expert review loop (valid v0 structured syntax).

provider xai.grok_expert {
  model = "grok-3"
  temperature = 0.1
}

provider comfy.flux_klein {
  endpoint = "comfyui://127.0.0.1:8000"
  workflow = "flux_klein_4b_distilled.json"
}

provider comfy.ltx_23 {
  endpoint = "comfyui://127.0.0.1:8000"
  workflow = "ltx_2_3_dev_fp8_i2v.json"
}

tool generate_cat_frame {
  description = "Generate base or motion frame for Pawfall cat mood using Flux/LTX"
  schema = { prompt = "string", seed = "number", mood = "string" }
  provider = provider.comfy.flux_klein
}

tool expert_review {
  description = "Run multi-expert Grok review on animation frames for six dimensions"
  schema = { animation = "string", frames = "array", motionPrompt = "string" }
  provider = provider.xai.grok_expert
}

template cat_motion {
  prompt = "the cat {motion}, static camera, body remains in same position, cat-like weight, deliberate paw placement, tail counterbalance"
}

policy asset_policy {
  sandbox = true
  rateLimit = 10
  allowedTools = ["generate_cat_frame", "expert_review"]
}

eval expert_cat_review {
  criteria = ["LeadAnimator motion", "CatEthologist behavior", "GameplayDesigner utility for platformer"]
  threshold = 4.5
  llm = provider.xai.grok_expert
}

workflow cat_review_iteration {
  steps = ["gen", "review", "fix"]
  parallel = false
  retries = 3
  policy = policy.asset_policy
}

autonomous-session pawfall_cat_moods {
  description = "Generate, review, and iterate cat animations for every mood until approved for Pawfall."
  lanes = [
    { name = "asset_gen", steps = [ { type = "tool", tool = "generate_cat_frame", forEach = ["idle_neutral", "swat", "pounce", "walk", "jump"] } ] },
    { name = "review_loop", steps = [ { type = "eval", eval = "expert_review", threshold = 4.2 }, { type = "workflow", workflow = "cat_review_iteration", checkpoint = "post_review" } ], dependsOn = ["asset_gen"] }
  ]
  checkpoints = ["post_gen", "post_review"]
  resumeOnRestart = true
}

route resolver -> xai.grok_expert

route swat -> xai.grok_expert {
  template = template.cat_motion
  motion = "reaches its raised right front paw forward in a deliberate swatting motion"
  loop = false
  fps = 12
}

agent pawfall_cat {
  prompt = "cute expressive cartoon house cat, full body, plain white background"
}