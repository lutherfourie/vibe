// Vibe describing its own near-term work.
// This file is intentionally small. Future syntax may grow real lane and gate
// primitives; for now, lane-shaped work is represented as plugins consumed by
// one bootstrap agent.

provider cerebras.glm_4_7 { mode = api }
provider openai.codex     { mode = cli }

surface codex.local {
  kind     = codex
  mode     = local
  guidance = "AGENTS.md"
  skills   = "./.agents/skills"
}

surface codex.cli {
  kind   = codex
  mode   = cli
  binary = "codex"
}

surface codex.cloud {
  kind         = codex
  mode         = cloud
  environment = "chatgpt.com/codex"
}

surface codex.github_pr {
  kind    = codex
  mode    = github_pr
  trigger = "@codex"
}

surface vscode.agent_admin {
  kind             = ide
  mode             = vscode
  codex_extension  = "openai.chatgpt"
  claude_extension = "anthropic.claude-code"
  tasks            = ".vscode/tasks.json"
  guidance         = ["AGENTS.md", "CLAUDE.md"]
}

route resolver      -> cerebras.glm_4_7
route researcher    -> cerebras.glm_4_7
route implementation -> openai.codex
fallback            -> cerebras.glm_4_7

persona vibe_bootstrap_voice {
  description = "pragmatic Vibe bootstrapper; keeps the spec fluid while making useful artifacts"
}

memory vibe_project {
  kind      = vault
  namespace = "C:/vibe"
}

harness self_making {
  kind = planner_generator_evaluator
}

plugin research_lane {
  impl  = "./tools/research-lane"
  owns  = "docs/superpowers/research/**"
  emits = "decision notes and framework maps"
}

plugin language_lane {
  impl  = "./tools/language-lane"
  owns  = "packages/language/**"
  emits = "parser, dispatcher, resolver, and validation changes"
}

plugin runtime_spike_lane {
  impl  = "./tools/runtime-spike-lane"
  owns  = "go/**"
  emits = "provisional local tooling"
}

plugin execution_surface_lane {
  impl  = "./tools/execution-surface-lane"
  owns  = "docs/** examples/**"
  emits = "explicit handling for phone, web, IDE, GitHub, local desktop, and cloud-agent control"
}

plugin bootstrap_tooling_lane {
  impl  = "./tools/bootstrap-tooling-lane"
  owns  = "docs/bootstrap-todos.md docs/local-toolkit.md"
  emits = "tooling and auth checklist for gh, Playwright browsers, jq, yq, fd, and plugins/connectors"
}

plugin local_toolkit_lane {
  impl     = "./tools/local-toolkit-lane"
  target   = surface.codex.local
  reads    = ["README.md", "docs/fresh-start.md", "examples/vibe-self.vibe"]
  owns     = "docs/local-toolkit.md go/** packages/**"
  verify   = ["pnpm run self:plan", "pnpm test", "pnpm run build"]
  approval = human.before_commit
  emits    = "small vibe CLI plan for doctor, lanes, handoff, verify, and memory"
}

plugin vscode_agent_lane {
  impl     = "./tools/vscode-agent-lane"
  target   = surface.vscode.agent_admin
  reads    = ["AGENTS.md", "CLAUDE.md", ".vscode/tasks.json", "packages/vscode-extension/src/extension.ts"]
  owns     = "AGENTS.md CLAUDE.md .vscode/** packages/vscode-extension/** docs/vscode-agent-workflow.md"
  verify   = ["pnpm --filter vibe-vscode test", "pnpm --filter vibe-vscode build", "pnpm run check"]
  approval = human.before_commit
  emits    = "VS Code command palette and Codex/Claude extension administration loop"
}

plugin human_merge_gate {
  impl  = "./tools/human-merge-gate"
  owns  = "review"
  emits = "approved next slice"
}

agent vibe_bootstrap {
  persona = persona.vibe_bootstrap_voice
  memory  = memory.vibe_project
  harness = harness.self_making
  uses    = [
    plugin.research_lane,
    plugin.language_lane,
    plugin.runtime_spike_lane,
    plugin.execution_surface_lane,
    plugin.bootstrap_tooling_lane,
    plugin.local_toolkit_lane,
    plugin.vscode_agent_lane,
    plugin.human_merge_gate
  ]
}
