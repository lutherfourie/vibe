# Local Supabase (for dev with live realtime)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-publishable-key>
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=<local-service-key>

# Hosted Supabase (vibe project gknrdzkdgmuozhtaonst - for Vercel/production live)
# These are set in Vercel envs for the project (Production) via CLI.
# NEXT_PUBLIC_SUPABASE_URL=https://gknrdzkdgmuozhtaonst.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<hosted-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<hosted-service-key>
# Retrieve: supabase projects api-keys --project-ref gknrdzkdgmuozhtaonst
# Add: vercel env add SUPABASE_URL https://gknrdzkdgmuozhtaonst.supabase.co production
#      vercel env add NEXT_PUBLIC_SUPABASE_URL https://gknrdzkdgmuozhtaonst.supabase.co production
#      vercel env add NEXT_PUBLIC_SUPABASE_ANON_KEY <anon> production
#      vercel env add SUPABASE_SERVICE_ROLE_KEY <service> production
# Confirmed project via .vercel/project.json + vercel whoami + env ls (PR #38)

# For real GLM/Cerebras in launches (add your key; /api/launch now supports forcing it).
# CEREBRAS_API_KEY=<your-key-here>
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# CEREBRAS_MODEL=zai-glm-4.7
#
# Force real Cerebras (no silent mock):
# - body.provider = "cerebras" in POST /api/launch (or set in dashboard form)
# - or env FORCE_CEREBRAS=true / DEFAULT_PROVIDER=cerebras
# If forced but key missing: clear 400 error + console.error (notifies instead of failing silently).
# If key present: real provider used for fast/cheap inference (even without explicit force).
# Without key and no force: falls back to mock 'cerebras.glm-demo' (with console.warn).
